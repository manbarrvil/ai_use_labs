"Prueba SAE"
C o m p i l a t i o n


   3   
   4  set
   5      n generadores / n1, n2, n3 /
   6  *    t períodos / t0*t24 /
   7      t períodos / t0*t4 /
   8      l cargas / l1*l2 / ;
   9   
  10  *set subt(t) ;
  11  *    subt(t) = yes ;
  12  *    subt("t0") = no ;
  13   
  14  scalar
  15      E capacidad SAE (kWh) / 10 /
  16      P potencia SAE (kW) / 5 /
  17      nc rendimiento de carga / 0.9 /
  18      nd rendimiento de descarga / 0.9 / ;
  19   
  20  *table
  21  *datgen(n,*) datos generadores
  22  *$ondelim
  23  *$include datos.csv
  24  *$offdelim  ;
  25   
  26  *table
  27  *datprecios(t,*)
  28  *$ondelim
  29  *$include precios.csv
  30  *$offdelim  ;
  31   
  32  *display datgen ;
  33   
  34   
  35  parameter
  36      a(n) coste cuadrático  /n1 0, n2 1, n3 1  /
  37      b(n) coste lineal      /n1 0.1, n2 0.15, n3 0.65  /
  38      c(n) coste fijo        /n1 0, n2 0.9, n3 0.8  /
  39      cd   coste deslastre   / 1 /
  40      Pgmax(n) potencia generada máxima  / n1 5, n2 2, n3 3  /
  41      Pgmin(n) potencia generada mínima  / n1 1, n2 0.2, n3 0  /
  42      Pl(l)    demanda carga l  / l1 2, l2 2 /
  43      lambda(t) nivel de carga / t0 0, t1 2, t2 1, t3 2, t4 1 / ;
  44   
  45  *Leido desde el csv
  46  *    a(n) = datgen(n,'a') ;
  47  *    b(n) = datgen(n,'b') ;
  48  *    c(n) = datgen(n,'c') ;
  49   
  50  variables
  51      coste coste total
  52      pg(n,t) potencia generada periodo t
  53      pdem(t) potencia demandada periodo t
  54      pc(t) carga SAE periodo t
  55      pd(t) descarga SAE periodo t
  56      soc(t) estado de carga periodo t ;
  57   
  58  equations
  59      eq_costes costes
  60      eq_balance balance de potencia
  61      eq_pdem  demanda horaria
  62      eq_soc estado de carga ;
  63   
  64  eq_costes.. coste =e= sum(t, sum(n, a(n)*pg(n,t)**2 +
  65                  b(n)*pg(n,t) + c(n) )) ;
  66   
  67  eq_balance(t)$(not sameas(t,"t0")).. sum(n, pg(n,t) ) +
  68                          pd(t) - pc(t) =e= pdem(t) ;
  69   
  70  eq_pdem(t)..    pdem(t) =e= lambda(t)*sum(l, Pl(l)) ;
  71  *eq_pdem(t)..    pdem(t) =e= lambda(t)*sum(l, datloads(t,l)) ;
  72   
  73  *eq_soc(subt(t)).. soc(t) =e= soc(t-1) +
  74  *                                pc(t)*nc - pd(t)/nd ;
  75   
  76  eq_soc(t)$(not sameas(t,"t0")).. soc(t) =e= soc(t-1) +
  77                                  pc(t)*nc - pd(t)/nd ;
  78   
  79  * límites en variables
  80  *Leido desde el csv
  81  *pg.lo(n,t) = datgen(n, 'Pmin') ;     # potencia mínima
  82  *pg.up(n,t) = datgen(n, 'Pmax') ;
  83  pg.lo(n,t) =  Pgmin(n);
  84  pg.up(n,t) =  Pgmax(n);
  85  soc.lo(t) = 0 ;
  86  soc.up(t) = E ;
  87  soc.fx("t0") = 0.1*E ;
  88  soc.fx("t4") = 0.1*E ;
  89  pc.lo(t) = 0 ;
  90  pc.up(t) = P ;
  91  pd.lo(t) = 0 ;
  92  pd.up(t) = P ;
  93   
  94  model opt_coste / all / ;
  95  solve opt_coste minimizing coste using nlp ;


