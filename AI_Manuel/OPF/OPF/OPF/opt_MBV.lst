G e n e r a l   A l g e b r a i c   M o d e l i n g   S y s t e m
C o m p i l a t i o n


   1   
   2  set
   3   
   4  n generadores /n1,n2,n3/
   5  l cargas /l1,l2/
   6  t tiempo /t1,t2,t3,t4/;
   7   
   8  scalar
   9  *Contantes que no dependen de conjuntos
  10   
  11  SOC_max SOC maximo kwh /10/
  12  P_max_bat Pot. maximo kw /5/
  13  eta_c Rendimiento de carga /0.9/
  14  eta_d Rendimiento de descarga  /0.9/
  15  Pmax_load Potencia maxima carga /4/
  16  delta_t incremento en tiempo /1/;
  17   
  18  parameters
  19   
  20  a(n)  termino cuadratico coste gen /n1 0, n2 1, n3 1/
  21  b(n)  termino lineal coste gen /n1 0.1, n2 0.15, n3 0.65/
  22  c(n)  termino independiente coste gen /n1 0, n2 0.9, n3 0.8/
  23  Pmax(n) potencia maxima cada gen /n1 5, n2 2, n3 0/
  24  Pmin(n) potencia minima cada gen /n1 1,n2 0.2,n3 0/
  25  lambda(t) porcentaje de carga en cada instante de tiempo /t1 1,t2 0.5,t3 1
      ,t4 0.5/ ;
  26   
  27  variables
  28   
  29  Pgen(n,t) Define potencia cada generador en cada inst de tiempo
  30  Pd(t) potencia de descarga de la bateria
  31  Pc(t) potencia de carga de la bateria
  32  SOC(t) estado de carga de la bateria
  33  coste(n,t) coste de cada generador en cada instante de tiempo
  34  coste_total coste total de todos los generadores en todos los instantes de
       tiempo;
  35   
  36  Pc.up(t) = P_max_bat;
  37  Pd.up(t) = P_max_bat;
  38  Pc.lo(t) = 0;
  39  Pd.lo(t) = 0;
  40  SOC.up(t)= SOC_max;
  41  SOC.lo(t)= 0;
  42  SOC.fx("t1")= SOC_max;
  43   
  44  equations
  45  eq_bal(t) ecuacion de balance
  46  eq_SOC(t) ecuacion del estado de carga
  47  eq_coste(n,t)  ecuacion de coste de cada generador
  48  eq_coste_total ecuacion total de costes
  49  eq_Pmax(n,t) ecuacion potencia maxima generadores
  50  eq_Pmin(n,t) ecuacion potencia minima generadores;
  51   
  52   
  53  eq_bal(t).. sum(n,Pgen(n,t)) + Pd(t) =e=  lambda(t)*Pmax_load*2 + Pc(t);
  54   
  55  eq_SOC(t)$(not sameas(t,"t1")).. SOC(t) =e= SOC(t-1) + Pc(t)*eta_c*delta_t
       - Pd(t)/eta_d*delta_t;
  56   
  57  eq_Pmax(n,t)..   Pgen(n,t) =l= Pmax(n);
  58   
  59  eq_Pmin(n,t)..   Pgen(n,t) =g= Pmin(n);
  60   
  61  eq_coste(n,t)..   coste(n,t) =e= a(n)*power(Pgen(n,t),2) + b(n)*Pgen(n,t) 
      + c(n);
  62   
  63  eq_coste_total..  coste_total =e= sum(n,sum(t,coste(n,t)));
  64   
  65  model Modelo_costes_gen_bate /all/    ;
  66  solve Modelo_costes_gen_bate minimizing coste_total using nlp;
  67   
  68   


